rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isTripMember(tripId) {
      return request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.members;
    }

    match /trips/{tripId} {
      // Non-members need to read the trip to verify the invite token before joining
      allow read: if request.auth != null &&
        (request.auth.uid in resource.data.members ||
         resource.data.inviteToken != null);

      allow create: if request.auth != null && request.auth.uid in request.resource.data.members;

      allow update: if request.auth != null && (
        request.auth.uid in resource.data.members ||
        // Joining via invite: trip has a token, user adds only themselves to members/memberDetails
        (resource.data.inviteToken != null &&
         request.auth.uid in request.resource.data.members &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['members', 'memberDetails']))
      );

      allow delete: if request.auth != null && request.auth.uid == resource.data.ownerId;
    }

    match /tickets/{ticketId} {
      allow read, write: if isTripMember(resource.data.tripId);
      allow create: if request.auth != null && isTripMember(request.resource.data.tripId);
    }

    match /expenses/{expenseId} {
      allow read, write: if isTripMember(resource.data.tripId);
      allow create: if request.auth != null && isTripMember(request.resource.data.tripId);
    }

    match /cars/{tripId} {
      allow read, write: if isTripMember(tripId);
    }

    // Ticket file blobs (base64) for cross-device access — keyed by random nanoid
    match /ticket-files/{fileId} {
      allow read, write: if request.auth != null;
    }
  }
}
