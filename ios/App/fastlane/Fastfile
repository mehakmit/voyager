default_platform(:ios)

platform :ios do
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id:        ENV["ASC_KEY_ID"],
      issuer_id:     ENV["ASC_ISSUER_ID"],
      key_filepath:  "#{ENV['HOME']}/.private_keys/AuthKey_#{ENV['ASC_KEY_ID']}.p8",
      duration:      1200,
      in_house:      false,
    )

    cert(api_key: api_key, output_path: "/tmp/certs")
    sigh(
      api_key:        api_key,
      app_identifier: "app.odyssey",
      output_path:    "/tmp/profiles",
      force:          false,
    )

    increment_build_number(
      build_number: ENV["BUILD_NUMBER"] || Time.now.to_i.to_s,
      xcodeproj:    "App.xcodeproj",
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      team_id:               "ACLCAVPU3N",
      bundle_identifier:     "app.odyssey",
      path:                  "App.xcodeproj",
      profile_uuid:          lane_context[SharedValues::SIGH_UDID],
    )

    build_app(
      project:        "App.xcodeproj",
      scheme:         "App",
      configuration:  "Release",
      export_method:  "app-store",
      xcargs:         "DEVELOPMENT_TEAM=ACLCAVPU3N",
      export_options: {
        teamID:               "ACLCAVPU3N",
        provisioningProfiles: {
          "app.odyssey" => "app.odyssey AppStore",
        },
      },
      output_directory: "/tmp/build",
      output_name:      "Odyssey.ipa",
    )

    upload_to_testflight(
      api_key:                           api_key,
      ipa:                               "/tmp/build/Odyssey.ipa",
      skip_waiting_for_build_processing: true,
    )
  end
end
