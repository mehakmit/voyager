default_platform(:ios)

platform :ios do
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id:       ENV["ASC_KEY_ID"],
      issuer_id:    ENV["ASC_ISSUER_ID"],
      key_filepath: "#{ENV['HOME']}/.private_keys/AuthKey_#{ENV['ASC_KEY_ID']}.p8",
      duration:     1200,
      in_house:     false,
    )

    increment_build_number(
      build_number: ENV["BUILD_NUMBER"] || Time.now.to_i.to_s,
      xcodeproj:    "App.xcodeproj",
    )

    # Enable automatic signing so Xcode manages certs/profiles via the API key
    update_code_signing_settings(
      use_automatic_signing: true,
      team_id:               "ACLCAVPU3N",
      bundle_identifier:     "app.odyssey",
      path:                  "App.xcodeproj",
    )

    build_app(
      project:       "App.xcodeproj",
      scheme:        "App",
      configuration: "Release",
      export_method: "app-store",
      xcargs:        "-allowProvisioningUpdates -authenticationKeyID #{ENV['ASC_KEY_ID']} -authenticationKeyIssuerID #{ENV['ASC_ISSUER_ID']} -authenticationKeyPath #{ENV['HOME']}/.private_keys/AuthKey_#{ENV['ASC_KEY_ID']}.p8 DEVELOPMENT_TEAM=ACLCAVPU3N",
      export_options: {
        teamID:       "ACLCAVPU3N",
        method:       "app-store",
        signingStyle: "automatic",
      },
      output_directory: "/tmp/build",
      output_name:      "Odyssey.ipa",
    )

    upload_to_testflight(
      api_key:                           api_key,
      ipa:                               "/tmp/build/Odyssey.ipa",
      skip_waiting_for_build_processing: true,
    )
  end
end
